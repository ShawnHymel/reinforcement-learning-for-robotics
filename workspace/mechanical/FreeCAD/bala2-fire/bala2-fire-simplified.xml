<?xml version="1.0" encoding="UTF-8"?>

<!-- MJCF -->
<!-- MuJoCo Format: XML for describing physical components of the robot and how
     they fit together. Reference: 
     https://mujoco.readthedocs.io/en/stable/XMLreference.html -->

<mujoco model="bala2-fire-simplified">

  <!-- ===================================================================== -->
  <!-- Settings -->

  <!-- Sets options for parser and compiler:
       angle: "degree" (MJCF default) or "radian"
       coordinate: positions/orientations expressed in "local" or "global" frame
       meshdir: absolute or relative path to STL files
       autolimits: automatically set limited="true" if range attribute given -->
  <compiler angle="radian"
            coordinate="local"
            meshdir="meshes"
            autolimits="true"/>

  <!-- Sets options for physics simulation:
       timestep: time between measurement/control steps in simulator
       gravity: gravitational acceleration vector
       integrator: algorithm used to compute positions/velocities -->
  <option timestep="0.005"
          gravity="0 0 -9.81"
          integrator="implicitfast"/>

  <!-- Specifies default values for various attributes -->
  <default>
    <!-- Geometry defaults: solid surfaces with reasonable friction
         contype: bit mask of which collision group the geom belongs to
         conaffinity: bit mask of which group this geom can collide with
         friction: coefficients (sliding, torsional, rolling)

         Note: contact friction between two geoms is the max of either
         geom friction values. 0.8 is an estimate for rubber on a floor/desk -->
    <geom contype="1" 
          conaffinity="1" 
          friction="0.8 0.005 0.0001"/>
  </default>

  <!-- ===================================================================== -->
  <!-- Assets: meshes and visual textures -->

  <!-- Define assets to use when building the world -->
  <asset>
    <!-- Define mesh, file location, and scale (convert to meters) -->
    <mesh name="chassis_mesh"
          file="chassis.stl"
          scale="0.001 0.001 0.001"/>
    <mesh name="wheel_left_mesh"
          file="wheel_left.stl"
          scale="0.001 0.001 0.001"/>
    <mesh name="wheel_right_mesh"
          file="wheel_right.stl"
          scale="0.001 0.001 0.001"/>

    <!-- Use simple gradient for sky texture -->
    <texture type="skybox"
             builtin="gradient"
             rgb1="0.5 0.7 1"
             rgb2="0.95 0.95 1"
             width="256"
             height="256"/>

    <!-- Use built-in checker pattern to create grid texture -->
    <texture name="grid"
             type="2d"
             builtin="checker"
             rgb1="0.2 0.3 0.4"
             rgb2="0.3 0.4 0.5"
             width="512"
             height="512"
             mark="cross"
             markrgb="0.8 0.8 0.8"/>

    <!-- Create a grid material from the grid texture  -->
    <material name="grid"
              texture="grid"
              texrepeat="5 5"
              reflectance="0"
              specular="0"
              shininess="0"/>
  </asset>

  <!-- ===================================================================== -->
  <!-- World and robot bodies -->

  <!-- The world and everything in it -->
  <worldbody>

    <!-- Lighting -->
    <light pos="0 0 1.5" 
           dir="0 0 -1" 
           diffuse="0.8 0.8 0.8"/>

    <!-- Ground plane at z=0, grid texture. If size x or y is set to 0, the 
         plane is infinitely wide/long with 0 size. We'll make it large but
         finite. -->
    <geom name="ground"
          type="plane"
          size="5 5 0.1"
          material="grid"/>

    <!-- Define the robot as a nested tree of bodies and joints. The origin of
         the chassis is the center of the axles, which sits 22.5 mm above the 
         ground (wheel radius). This allows the wheels to be touching the ground
         at the start of the episode. -->
    <body name="chassis" pos="0 0 0.0225">

      <!-- Free joint: robot can translate/orient freely in world frame -->
      <freejoint name="root"/>

      <!-- Visual and collision geometry. Made partly transparent to see the IMU
           site -->
      <geom name="chassis_geom"
            type="mesh"
            mesh="chassis_mesh"
            rgba="0.87 0.23 0.16 1.0"/>

      <!-- Chassis inertial properties (copied from FreeCAD script output) -->
      <inertial pos="0.000000 0.000000 0.017000" 
                mass="0.127000" 
                diaginertia="0.000056790 0.000054532 0.000058722"/>

      <!-- Site for IMU sensor: measured from the chassis's origin, displayed
           as a blue ball (will be inside chassis) -->
      <site name="imu_site"
            type="box"
            pos="-0.008 0.0225 0.040" 
            size="0.003 0.003 0.00035"
            rgba="0 0 1.0 1.0"/>

      <!-- Optional visual box to show the "front" of the robot -->
      <geom type="box"
            size="0.001 0.01 0.005" 
            pos="0.027 0 0.02"
            rgba="0 1.0 0 1.0" 
            contype="0" 
            conaffinity="0"/>

      <!-- Left wheel -->
      <body name="wheel_left" pos="0 0.04 0">

        <!-- Joint: connect body to its parent and defines motion
             type: free, ball, slide, hinge
             axis: rotate around one axis for hinge type
             damping: viscous resistance
             frictionloss: resistance to motion 
             armature: motor's rotational inertia reflected through the gearbox
                       Estimated rotational inertia of N20 motor: 5e-8 Kg-m^2.
                       With a 1:N gearbox, we multiply the inertia by N^2 to get
                       the reflected inertia. So, 5e-8 * 30^2 = 4.5e-5 Kg-m^2.
                       This is ~10x the wheel's inertia, so this dominates. -->
        <joint name="left_wheel_joint" 
               type="hinge" 
               axis="0 1 0"
               damping="0.001" 
               frictionloss="0.001"
               armature="4.5e-5"/>

        <!-- Assign a mesh and give it a color. Use default collision and
             friction values. -->
        <geom name="wheel_left_geom" 
              type="mesh" 
              mesh="wheel_left_mesh"
              rgba="0.1 0.1 0.1 1.0"/>

        <!-- Wheel inertial properties (copied from FreeCAD script output) -->
        <inertial pos="0.000000 0.000000 0.000000"
                  mass="0.017000" 
                  diaginertia="0.000002611 0.000004303 0.000002611"/>
      </body>

      <!-- Right wheel -->
      <body name="wheel_right" pos="0 -0.04 0">
        <joint name="right_wheel_joint" 
               type="hinge" 
               axis="0 1 0"
               damping="0.001" 
               frictionloss="0.001"
               armature="4.5e-5"/>
        <geom name="wheel_right_geom" 
              type="mesh" 
              mesh="wheel_right_mesh"
              rgba="0.1 0.1 0.1 1.0"/>
        <inertial pos="0.000000 0.000000 0.000000" 
                  mass="0.017000" 
                  diaginertia="0.000002611 0.000004303 0.000002611"/>
      </body>
    </body>
  </worldbody>

  <!-- ===================================================================== -->
  <!-- Actuators: motors driving the wheel joints -->

  <actuator>

    <!-- Left motor connected to the left wheel joint. Note that autolimits is
         set to "true" in the compiler element, which means that ctrlrange
         determines the limits of the actuator (i.e. ctrllimited is
         automatically set to "true").

         Control torque (for a hinge joint) is determined by gear * ctrl (units
         of N-m). For reinforcement learning, it helps to have a normalized
         ctrl, so we set the limits to [-1, 1]. With the gear set to 0.05, that
         gives us actual limits of -0.05 to 0.05 N-m, which is a decent estimate
         of our N20 motor with a 1:30 gearbox. --> 
    <motor name="left_motor"
           joint="left_wheel_joint" 
           gear="0.05"
           ctrlrange="-1 1"/>

    <!-- Right motor connected to the right wheel joint -->
    <motor name="right_motor" 
           joint="right_wheel_joint" 
           gear="0.05"
           ctrlrange="-1 1"/>
  </actuator>

  <!-- ===================================================================== -->
  <!-- Sensors: IMU and encoders -->

  <!-- Define all the sensors and their locations -->
  <sensor>
    <!-- IMU sensors at imu_site. While our MPU6886 only provides gyro and
         acceleration data, we can get ground-truth orientation here to help
         us with training (even if we don't have it on the real robot). -->
    <accelerometer name="imu_accel" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
    <framequat name="imu_orientation" objtype="site" objname="imu_site"/>

    <!-- Wheel encoders (joint position and velocity) -->
    <jointpos name="left_wheel_pos" joint="left_wheel_joint"/>
    <jointpos name="right_wheel_pos" joint="right_wheel_joint"/>
    <jointvel name="left_wheel_vel" joint="left_wheel_joint"/>
    <jointvel name="right_wheel_vel" joint="right_wheel_joint"/>
  </sensor>

</mujoco>