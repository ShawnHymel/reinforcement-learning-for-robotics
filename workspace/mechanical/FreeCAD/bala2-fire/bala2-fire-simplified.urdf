<?xml version="1.0"?>

<!-- URDF -->
<!-- Specifies physical components of the robot and how they fit together
     Note: ROS standard assumes X-axis is forward/backward for the robot -->

<robot name="bala2-fire-simplified">

  <!-- ===================================================================== -->
  <!-- Links (rigid body components) -->

  <!-- Chassis -->
  <link name="chassis">

    <!-- Specifies how to render the component -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Load STL file, specify unit conversion to meters -->
        <mesh filename="meshes/chassis.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <!-- Red color, opaque -->
      <material name="chassis_red">
        <color rgba="0.87 0.23 0.16 1.0"/>
      </material>
    </visual>

    <!-- Provides collision body (can be different than <visual>)-->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/chassis.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <!-- Defines the mass properties of the body -->
    <inertial>
      <origin xyz="0.000000 0.000000 0.017000" rpy="0 0 0"/>
      <mass value="0.127000"/>
      <inertia ixx="0.000056790"
               iyy="0.000054532"
               izz="0.000058722"
               ixy="0.000000000"
               ixz="0.000000000"
               iyz="0.000000000"/>
    </inertial>
  </link>

  <!-- Left wheel -->
  <link name="wheel_left">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.017000"/>
      <inertia ixx="0.000002611"
               iyy="0.000004303"
               izz="0.000002611"
               ixy="0.000000000"
               ixz="0.000000000"
               iyz="0.000000000"/>
    </inertial>
  </link>

  <!-- Right wheel -->
  <link name="wheel_right">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.000000 0.000000 0.000000" rpy="0 0 0"/>
      <mass value="0.017000"/>
      <inertia ixx="0.000002611"
               iyy="0.000004303"
               izz="0.000002611"
               ixy="0.000000000"
               ixz="0.000000000"
               iyz="0.000000000"/>
    </inertial>
  </link>

  <!-- ===================================================================== -->
  <!-- Joints (how the links are connected) -->

  <!-- Left wheel joint -->
  <!-- Type options:
       fixed: rigid attachment (no motion)
       revolute: rotational with angle limits
       continuous: rotational without limits
       prismatic: linear translation with limits
       planar: 2D motion in a plane
       floating: full 6-DoF motion -->
  <joint name="left_wheel_joint" type="continuous">
    <!-- Parent stays still (in joints frame of reference), child moves -->
    <parent link="chassis"/>
    <child  link="wheel_left"/>

    <!-- Joint's origin is (x, y, z) meters from the parent's frame origin -->
    <!-- and rotated (r, p, y) radians -->
    <origin xyz="0 0.040 0" rpy="0 0 0"/>

    <!-- Child can freely rotate around the Y-axis in the joint's frame -->
    <axis xyz="0 1 0"/>

    <!-- Passive forces acting on the joint -->
    <dynamics damping="0.001" friction="0.001"/>
  </joint>

  <!-- Right wheel joint -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child  link="wheel_right"/>
    <origin xyz="0 -0.040 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.001" friction="0.001"/>
  </joint>

</robot>