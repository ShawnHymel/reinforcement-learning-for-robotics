<?xml version="1.0"?>
<robot name="bala2">

  <!-- ============================================================== -->
  <!-- Bala2 Fire balance bot                                          -->
  <!--                                                                  -->
  <!-- Coordinate convention: ROS (X=forward, Y=left, Z=up)             -->
  <!-- Mesh files in mm, scaled to m via the mesh scale attribute.      -->
  <!--                                                                  -->
  <!-- Mass:  ~159g total (chassis 125g measured + 2 wheels @ 17g)      -->
  <!-- CoM:   chassis CoM at z=18mm above the wheel-axle plane          -->
  <!-- ============================================================== -->

  <!-- ===== CHASSIS ===== -->
  <link name="chassis">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/chassis.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.3 0.3 0.4 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/chassis.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.018" rpy="0 0 0"/>
      <mass value="0.125000"/>
      <inertia ixx="0.000059379" iyy="0.000056717" izz="0.000057370"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>

  <!-- ===== LEFT WHEEL ===== -->
  <link name="wheel_left">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.017000"/>
      <inertia ixx="0.000001620" iyy="0.000002603" izz="0.000001620"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>

  <!-- ===== RIGHT WHEEL ===== -->
  <link name="wheel_right">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wheel_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.017000"/>
      <inertia ixx="0.000001620" iyy="0.000002603" izz="0.000001620"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>

  <!-- ============================================================== -->
  <!-- JOINTS                                                           -->
  <!-- Continuous joint = revolute with no angle limits (wheels spin    -->
  <!-- freely). Tiny damping/friction for numerical stability.          -->
  <!-- ============================================================== -->

  <joint name="left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child  link="wheel_left"/>
    <origin xyz="0 0.0355 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.001" friction="0.001"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child  link="wheel_right"/>
    <origin xyz="0 -0.0355 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.001" friction="0.001"/>
  </joint>

</robot>